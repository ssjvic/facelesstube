{
    "appId": "com.facelesstube.app",
    "appName": "FacelessTube",
    "webDir": "dist",
    "server": {
        "androidScheme": "https"
    },
    "plugins": {
        "SplashScreen": {
            "launchShowDuration": 2000,
            "launchAutoHide": true,
            "backgroundColor": "#0a0a12",
            "androidSplashResourceName": "splash",
            "showSpinner": false
        },
        "FirebaseAuthentication": {
            "skipNativeAuth": false,
            "providers": [
                "google.com"
            ]
        }
    }
}